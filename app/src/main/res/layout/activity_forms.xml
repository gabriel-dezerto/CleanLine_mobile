<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FormsActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/azul_escuro"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="230dp"
            android:layout_height="58dp"
            android:layout_gravity="start"
            android:adjustViewBounds="true"
            android:paddingStart="6dp"
            android:scaleType="fitStart"
            android:src="@drawable/logo_home" />

    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pergunta 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Materiais, ferramentas e objetos estão em seus devidos lugares, sem obstruções ou itens desnecessários espalhados?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP1Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP1Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP1Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP1Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP1Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Pisos, bancadas, mesas e equipamentos estão livres de poeira, manchas ou resíduos visíveis?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP2Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP2Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP2Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP2Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP2Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="As lixeiras estão adequadas, corretamente separadas e sem acúmulo excessivo de lixo?
"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP3Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP3Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP3Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP3Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP3Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Etiquetas de localização, quadros informativos e sinalizações internas estão limpos, legíveis e atualizados?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP4Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP4Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP4Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP4Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP4Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Máquinas, computadores e ferramentas estão limpos e em bom estado de funcionamento?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP5Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP5Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP5Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP5Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP5Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Cantos, atrás de móveis e partes altas estão livres de poeira, teias ou sujeira acumulada?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP6Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP6Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP6Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP6Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP6Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 7 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="O ambiente está livre de odores desagradáveis, mofo ou sinais de insetos e roedores?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP7Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP7Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP7Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP7Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP7Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <!-- Pergunta 8 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtPergunta8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="O setor segue corretamente as rotinas de limpeza e manutenção estabelecidas pela empresa?"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgPergunta8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/rbP8Exc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Excelente" />

                    <RadioButton
                        android:id="@+id/rbP8Bom"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bom" />

                    <RadioButton
                        android:id="@+id/rbP8Ok"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ok" />

                    <RadioButton
                        android:id="@+id/rbP8Ruim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruim" />

                    <RadioButton
                        android:id="@+id/rbP8Pes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péssimo" />

                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:background="@drawable/bg_bloco_pergunta"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvNota"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Nota do setor:"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Digite a nota de 0 a 10"
                    android:inputType="number"
                    android:padding="12dp" />

            </LinearLayout>



        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>